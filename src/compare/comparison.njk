---
layout: layouts/base.njk
pagination:
  data: comparisons
  size: 1
  alias: comp
permalink: "/compare/{{ comp.slug }}/"
eleventyComputed:
  pageTitle: "{{ comp.cityA.name }} vs. {{ comp.cityB.name }}: 2026 Digital Nomad Comparison"
  pageDescription: "{{ comp.description }}"
---

<div class="section-container mt-16">
    {# Hero #}
    <div class="comparison-hero text-center mb-16">
        <div class="badge-2026 mb-4">
            <span class="badge-dot"></span>
            Verified {{ site.year }} Comparison
        </div>
        <h1 class="aura-title large-title">{{ comp.cityA.name }} vs. {{ comp.cityB.name }}<br>{{ comp.theme }} ({{ site.year }})</h1>
        <p class="text-dim subtitle-text max-800">{{ comp.emoji }} {{ comp.description }}</p>
    </div>

    {# Side-by-Side Cards #}
    <div class="comparison-grid grid-2 stack-on-mobile">
        {# City A #}
        <div class="comp-card glass-panel p-8 aura-border-primary">
            <h2 class="aura-title mb-6">{{ comp.cityA.name }}, {{ comp.cityA.country }}</h2>
            <div class="stat-rows">
                <div class="stat-row"><span>Visa Type</span> <strong>{{ comp.cityA.visa }}</strong></div>
                <div class="stat-row"><span>Tax Rate</span> <strong>{{ comp.cityA.tax | percentInt }}</strong></div>
                <div class="stat-row"><span>Monthly COL</span> <strong>${{ comp.cityA.col | localeString }}</strong></div>
                <div class="stat-row"><span>Average Rent</span> <strong>${{ comp.cityA.rent | localeString }}</strong></div>
                <div class="stat-row"><span>Min. Income</span> <strong>${{ comp.cityA.visaMinIncome | localeString }}/mo</strong></div>
                <div class="stat-row"><span>Nomad Score</span> <strong>{{ comp.cityA.score }}/100</strong></div>
                <div class="stat-row highlight-row">
                    <span>Savings @ $100k/yr</span>
                    <strong class="{% if comp.savingsA > comp.savingsB %}positive-text{% endif %}">${{ comp.savingsA | localeString }}/mo</strong>
                </div>
            </div>
            <div class="verdict-box mt-6 {% if comp.savingsA > comp.savingsB %}winner-box{% endif %}">
                <p><strong>{% if comp.savingsA > comp.savingsB %}✅ Winner for Wealth Accumulation{% else %}Premium Cost Profile{% endif %}</strong></p>
            </div>
        </div>

        {# City B #}
        <div class="comp-card glass-panel p-8 aura-border-secondary">
            <h2 class="aura-title mb-6">{{ comp.cityB.name }}, {{ comp.cityB.country }}</h2>
            <div class="stat-rows">
                <div class="stat-row"><span>Visa Type</span> <strong>{{ comp.cityB.visa }}</strong></div>
                <div class="stat-row"><span>Tax Rate</span> <strong>{{ comp.cityB.tax | percentInt }}</strong></div>
                <div class="stat-row"><span>Monthly COL</span> <strong>${{ comp.cityB.col | localeString }}</strong></div>
                <div class="stat-row"><span>Average Rent</span> <strong>${{ comp.cityB.rent | localeString }}</strong></div>
                <div class="stat-row"><span>Min. Income</span> <strong>${{ comp.cityB.visaMinIncome | localeString }}/mo</strong></div>
                <div class="stat-row"><span>Nomad Score</span> <strong>{{ comp.cityB.score }}/100</strong></div>
                <div class="stat-row highlight-row">
                    <span>Savings @ $100k/yr</span>
                    <strong class="{% if comp.savingsB > comp.savingsA %}positive-text{% endif %}">${{ comp.savingsB | localeString }}/mo</strong>
                </div>
            </div>
            <div class="verdict-box mt-6 {% if comp.savingsB > comp.savingsA %}winner-box{% endif %}">
                <p><strong>{% if comp.savingsB > comp.savingsA %}✅ Winner for Wealth Accumulation{% else %}Premium Cost Profile{% endif %}</strong></p>
            </div>
        </div>
    </div>

    {# Expert Analysis #}
    <div class="expert-analysis-container mt-16">
        <div class="glass-panel p-10">
            <h2 class="aura-title mb-8">{{ site.year }} Strategic Analysis: {{ comp.theme }}</h2>
            <div class="analysis-prose">
                <p><strong>{{ comp.cityA.name }}</strong> ({{ comp.cityA.country }}): {{ comp.cityA.intro }}</p>
                <p class="mt-6"><strong>{{ comp.cityB.name }}</strong> ({{ comp.cityB.country }}): {{ comp.cityB.intro }}</p>
                <p class="mt-6 highlight-text">At a $100,000 annual income, <strong>{{ comp.winner }}</strong> delivers higher monthly savings. {{ comp.cityA.name }} leaves you with <strong>${{ comp.savingsA | localeString }}/month</strong> while {{ comp.cityB.name }} leaves you with <strong>${{ comp.savingsB | localeString }}/month</strong> — a difference of <strong>${{ (comp.savingsA - comp.savingsB) | abs | localeString }}/month</strong>.</p>
            </div>

            {# Nomad Verdict #}
            <div class="expert-verdict-card mt-12 p-8">
                <div class="expert-verdict-content">
                    <div class="expert-avatar">👨‍💻</div>
                    <div class="expert-text">
                        <h3 class="aura-primary mb-4">2026 Nomad Expert Verdict</h3>
                        <p class="italic-dim">"For nomads prioritizing <strong>wealth accumulation</strong>, {{ comp.winner }} is the clear winner in 2026. However, if your business requires a <strong>stronger networking hub</strong>, {{ comp.cityA.name if comp.winner == comp.cityB.name else comp.cityB.name }} often provides better value for your time despite the slightly lower savings rate."</p>
                        <div class="verdict-tags mt-6">
                            <span class="badge-2026 tag-success">🚀 Best for Networking</span>
                            <span class="badge-2026 tag-success">📉 Low Tax Friction</span>
                            <span class="badge-2026 tag-info">🏡 Housing Availability: Fair</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {# Toolkits #}
        <div class="mt-16">
            {% include "partials/relocation-toolkit.njk" %}
        </div>
    </div>

    {# Inline Comparison Calculator #}
    <div class="app-container mt-16">
        <div class="calculator-column">
            {% set compareMode = true %}
            {% set destA = comp.cityA.countrySlug %}
            {% set destB = comp.cityB.countrySlug %}
            {% include "partials/calculator.njk" %}
        </div>

        <div class="results-column">
            {# Pro Report Upsell #}
            <div id="pro-upsell" class="glass-panel upsell-panel">
                <div class="upsell-container">
                    <div class="upsell-content">
                        <div class="badge-2026 upsell-badge">PREMIUM COMPARISON</div>
                        <h3 class="upsell-title">Unlock Full Arbitrage Report</h3>
                        <ul class="upsell-features">
                            <li>Side-by-Side 2026 Tax Arbitrage Strategy</li>
                            <li>Local Apartment & Utility Cost Gap Analysis</li>
                            <li>Visa Setup & Legal Roadmap for Both Cities</li>
                            <li>Exclusive "Nomad Winner" Financial Model</li>
                        </ul>
                        {% set tierA = pricing.getCountryTier(comp.cityA.country) %}
                        {% set tierB = pricing.getCountryTier(comp.cityB.country) %}
                        {% set finalTier = tierA if tierA > tierB else tierB %}
                        {% set finalPrice = pricing.tiers[finalTier].price %}
                        <div class="upsell-footer">
                            <div class="upsell-price">${{ finalPrice }}</div>
                            <button id="unlock-pro-btn" class="action-btn upsell-btn" data-price="{{ finalPrice }}">Unlock Pro →</button>
                        </div>
                    </div>
                    <div class="upsell-visual">
                        <img src="/assets/images/pro-mockup.png" alt="Pro Report Mockup" class="pro-mockup">
                    </div>
                </div>
            </div>

            {# Pro Report (Premium View - Optional for Comparison) #}
            {# {% include "partials/pro-report.njk" %} #}

            {# Lead Magnet #}
            {% include "partials/lead-magnet.njk" %}
        </div>
    </div>

    {# Related Comparisons #}
    <div class="section-container mt-24">
        <h2 class="aura-title text-center mb-8">More Strategic Comparisons</h2>
        <div class="stack-grid">
            {% set relatedCount = 0 %}
            {% for related in comparisons %}
                {% if related.slug != comp.slug and relatedCount < 4 %}
                    {% if related.cityA.slug == comp.cityA.slug or related.cityB.slug == comp.cityA.slug or related.cityA.slug == comp.cityB.slug or related.cityB.slug == comp.cityB.slug %}
                        {% set relatedCount = relatedCount + 1 %}
                        <a href="/compare/{{ related.slug }}/" class="stack-item glass-panel hub-card">
                            <div class="hub-icon">{{ related.emoji }}</div>
                            <div class="hub-info">
                                <div class="hub-name">{{ related.cityA.name }} vs. {{ related.cityB.name }}</div>
                                <div class="hub-desc">{{ related.theme }}</div>
                            </div>
                        </a>
                    {% endif %}
                {% endif %}
            {% endfor %}
        </div>
        
        <div class="mt-16">
            {% include "partials/seo-silos.njk" %}
        </div>
    </div>
</div>
