---
layout: layouts/base.njk
pagination:
  data: countryComparisons
  size: 1
  alias: comp
permalink: "/compare/country/{{ comp.slug }}/"
eleventyComputed:
  pageTitle: "{{ comp.countryA.name }} vs. {{ comp.countryB.name }}: 2026 Digital Nomad Comparison"
  pageDescription: "{{ comp.description }}"
---

<div class="section-container mt-16">
    {# Hero #}
    <div class="comparison-hero text-center mb-16">
        <div class="badge-2026 mb-4">
            <span style="display:inline-block; width:8px; height:8px; background:#10b981; border-radius:50%; margin-right:5px;"></span>
            Verified {{ site.year }} Visa Analysis
        </div>
        <h1 class="aura-title">{{ comp.countryA.name }} vs. {{ comp.countryB.name }}<br>{{ site.year }} Digital Nomad Comparison</h1>
        <p class="text-dim" style="font-size: 1.15rem; max-width: 800px; margin: 1rem auto 0;">⚖️ {{ comp.description }}</p>
    </div>

    {# Side-by-Side Cards #}
    <div class="comparison-grid">
        {# Country A #}
        <div class="comp-card" style="border-top: 6px solid var(--aura-primary);">
            <div class="flex-between mb-6">
                <h3 style="margin: 0;">{{ comp.countryA.name }}</h3>
                <span style="font-size: 2rem;">{{ comp.countryA.code | countryEmoji }}</span>
            </div>
            <div class="stat-row"><span>Visa Name:</span> <strong>{{ comp.countryA.visaName }}</strong></div>
            <div class="stat-row"><span>Tax Rate:</span> <strong {% if comp.countryA.tax < comp.countryB.tax %}style="color: var(--aura-accent);"{% endif %}>{{ comp.countryA.tax | percentInt }}</strong></div>
            <div class="stat-row"><span>Tax Details:</span> <strong style="font-size: 0.85rem;">{{ comp.countryA.taxType }}</strong></div>
            <div class="stat-row"><span>Min. Income:</span> <strong {% if comp.countryA.minIncomeMonthly < comp.countryB.minIncomeMonthly %}style="color: var(--aura-accent);"{% endif %}>${{ comp.countryA.minIncomeMonthly | localeString }}/mo</strong></div>
            <div class="stat-row"><span>Visa Duration:</span> <strong>{{ comp.countryA.visaDuration }}</strong></div>
            <div class="stat-row"><span>Processing Time:</span> <strong>{{ comp.countryA.processingTime }}</strong></div>
            
            <div class="verdict-box" {% if comp.countryA.tax < comp.countryB.tax %}style="border-color: var(--aura-accent); background: rgba(16, 185, 129, 0.05);"{% endif %}>
                <p><strong>{% if comp.countryA.tax < comp.countryB.tax %}✅ Lower Tax Rate{% else %}Higher Tax Bracket{% endif %}</strong></p>
            </div>

            <h4 class="mt-8 mb-2">Key Highlights</h4>
            <ul class="text-dim" style="font-size: 0.9rem; padding-left: 1.2rem;">
                {% for highlight in comp.countryA.highlights %}
                <li>{{ highlight }}</li>
                {% endfor %}
            </ul>
        </div>

        {# Country B #}
        <div class="comp-card" style="border-top: 6px solid var(--aura-secondary);">
            <div class="flex-between mb-6">
                <h3 style="margin: 0;">{{ comp.countryB.name }}</h3>
                <span style="font-size: 2rem;">{{ comp.countryB.code | countryEmoji }}</span>
            </div>
            <div class="stat-row"><span>Visa Name:</span> <strong>{{ comp.countryB.visaName }}</strong></div>
            <div class="stat-row"><span>Tax Rate:</span> <strong {% if comp.countryB.tax < comp.countryA.tax %}style="color: var(--aura-accent);"{% endif %}>{{ comp.countryB.tax | percentInt }}</strong></div>
            <div class="stat-row"><span>Tax Details:</span> <strong style="font-size: 0.85rem;">{{ comp.countryB.taxType }}</strong></div>
            <div class="stat-row"><span>Min. Income:</span> <strong {% if comp.countryB.minIncomeMonthly < comp.countryA.minIncomeMonthly %}style="color: var(--aura-accent);"{% endif %}>${{ comp.countryB.minIncomeMonthly | localeString }}/mo</strong></div>
            <div class="stat-row"><span>Visa Duration:</span> <strong>{{ comp.countryB.visaDuration }}</strong></div>
            <div class="stat-row"><span>Processing Time:</span> <strong>{{ comp.countryB.processingTime }}</strong></div>

            <div class="verdict-box" {% if comp.countryB.tax < comp.countryA.tax %}style="border-color: var(--aura-accent); background: rgba(16, 185, 129, 0.05);"{% endif %}>
                <p><strong>{% if comp.countryB.tax < comp.countryA.tax %}✅ Lower Tax Rate{% else %}Higher Tax Bracket{% endif %}</strong></p>
            </div>

            <h4 class="mt-8 mb-2">Key Highlights</h4>
            <ul class="text-dim" style="font-size: 0.9rem; padding-left: 1.2rem;">
                {% for highlight in comp.countryB.highlights %}
                <li>{{ highlight }}</li>
                {% endfor %}
            </ul>
        </div>
    </div>

    {# Expert Analysis #}
    <div class="expert-analysis mt-16">
        <h2 class="mb-8">{{ site.year }} Strategic Analysis</h2>
        <p><strong>{{ comp.countryA.name }}</strong>: {{ comp.countryA.intro }}</p>
        <p class="mt-6"><strong>{{ comp.countryB.name }}</strong>: {{ comp.countryB.intro }}</p>
        
        <div class="glass-panel mt-8" style="border-left: 4px solid var(--aura-accent);">
            <p style="margin-bottom: 0;"><strong>Financial Verdict:</strong> 
            {% if comp.countryA.tax < comp.countryB.tax %}
            {{ comp.countryA.name }} offers a significant tax advantage with a {{ comp.countryA.tax | percentInt }} rate compared to {{ comp.countryB.name }}'s {{ comp.countryB.tax | percentInt }}.
            {% elif comp.countryB.tax < comp.countryA.tax %}
            {{ comp.countryB.name }} is the tax winner here, offering a {{ comp.countryB.tax | percentInt }} rate versus {{ comp.countryA.name }}'s {{ comp.countryA.tax | percentInt }}.
            {% else %}
            Both countries offer similar tax profiles, so your decision should focus on lifestyle and visa duration.
            {% endif %}
            </p>
        </div>

        {# Nomad Verdict #}
        <div class="glass-panel mt-8" style="border-left: 4px solid var(--aura-primary); background: rgba(59, 130, 246, 0.05);">
            <div class="expert-verdict-content" style="display: flex; gap: 1.5rem;">
                <div class="expert-icon" style="font-size: 2.5rem;">🛂</div>
                <div>
                    <h3 style="color: var(--aura-primary);" class="mb-4">2026 Residency Strategy</h3>
                    <p style="font-style: italic;" class="text-dim">"For long-term nomads looking for a <strong>path to permanent residency</strong>, {{ comp.countryA.name if comp.countryA.residencyPath else comp.countryB.name }} is historically the more stable choice. However, {{ comp.countryB.name if comp.countryA.residencyPath else comp.countryA.name }} offers a much faster 'Entry-to-Stay' timeline, which is ideal if you need to relocate within 30 days."</p>
                    <div class="mt-6 stack-on-mobile" style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
                        <div class="badge-2026" style="background: rgba(59, 130, 246, 0.1); border-color: rgba(59, 130, 246, 0.3);">⏱️ Fast Approval</div>
                        <div class="badge-2026" style="background: rgba(59, 130, 246, 0.1); border-color: rgba(59, 130, 246, 0.3);">📜 Simple Paperwork</div>
                        <div class="badge-2026" style="background: rgba(59, 130, 246, 0.1); border-color: rgba(59, 130, 246, 0.3);">💳 Renewal: Automatic</div>
                    </div>
                </div>
            </div>
        </div>

        {# Relocation Toolkit #}
        <div class="mt-16">
            {# We pass countryA as the primary context for the toolkit #}
            {% set country = comp.countryA %}
            {% include "partials/relocation-toolkit.njk" %}
        </div>
    </div>

    {# Lead Magnet #}
    {% include "partials/lead-magnet.njk" %}

    {# Related Comparisons #}
    <div class="mt-16">
        <h2 class="text-center mb-8">More Country Comparisons</h2>
        <div class="partner-grid">
            {% for related in countryComparisons | slice(0, 13) %}
            {% if related.slug != comp.slug %}
            <a href="/compare/country/{{ related.slug }}/" class="partner-card">
                <h4>{{ related.countryA.name }} vs. {{ related.countryB.name }}</h4>
                <p>Visa & Tax Analysis</p>
            </a>
            {% endif %}
            {% endfor %}
        </div>
    </div>
</div>
