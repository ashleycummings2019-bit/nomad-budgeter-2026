---

<div class="app-container">
    {# Calculator Sidebar #}
    {% include "partials/calculator.njk" %}

    {# Results Panel (hidden until calculation) #}
    <section id="results-panel" class="glass-panel hidden">
        <div class="results-header">
            <div class="header-info">
                <h2 class="aura-title">Financial Analysis</h2>
                <div class="header-meta">
                    <p id="city-badge" class="city-badge">London, United Kingdom</p>
                    <span class="meta-dot"></span>
                    <p class="trust-indicator"><span id="trust-signal">18</span> nomads calculating live</p>
                </div>
            </div>
            <div style="display: flex; gap: 1rem; align-items: center;">
                <button id="share-results-btn" class="glass-btn-sm" title="Share My Results">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align: middle; margin-right: 4px;"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"></path><polyline points="16 6 12 2 8 6"></polyline><line x1="12" y1="2" x2="12" y2="15"></line></svg>
                    Share
                </button>
                <div class="aura-score" id="aura-ring">
                    <span id="aura-value">85</span>
                </div>
            </div>
        </div>

        <div class="metric-grid">
            <div class="metric-card">
                <div class="metric-label">Take-Home Pay (Monthly)</div>
                <div class="metric-value highlight" id="res-net-monthly">$0</div>
            </div>
            <div class="metric-card">
                <div class="metric-label">Effective Tax Rate</div>
                <div class="metric-value" id="res-tax-rate">0%</div>
            </div>
            <div class="metric-card">
                <div class="metric-label">Cost of Living Index</div>
                <div class="metric-value" id="res-col-index">High</div>
            </div>
            <div class="metric-card">
                <div class="metric-label">Monthly Savings Potential</div>
                <div class="metric-value positive" id="res-savings">$0</div>
            </div>
        </div>

        <div id="visa-roi-card" class="metric-card roi-tracker hidden">
            <div class="flex-between mb-4">
                <div class="roi-info">
                    <div class="metric-label accent-color">Visa ROI Tracker</div>
                    <p class="roi-desc">Time to recover visa & setup costs via tax savings.</p>
                </div>
                <div class="roi-stats">
                    <div class="metric-value positive" id="res-payback">0 Months</div>
                    <div class="roi-yearly-savings" id="res-roi-savings">+$0 / yr</div>
                </div>
            </div>
            <a href="https://citizenremote.com/?ref=nomadbudgeter" target="_blank" rel="sponsored noopener" id="visa-cta" class="action-btn w-full accent-bg">Apply for Digital Nomad Visa →</a>
        </div>

        {# Success Stack (Affiliates) #}
        <div class="success-stack-section">
            <h3 class="section-subtitle">Your Nomad Success Stack</h3>
            <div class="stack-grid">
                <a href="{{ site.affiliates.safetywing.url }}" target="_blank" rel="sponsored noopener" class="stack-item glass-panel">
                    <div class="stack-icon">🛡️</div>
                    <div class="stack-info">
                        <div class="stack-name">SafetyWing</div>
                        <div class="stack-desc">Global Health Cover</div>
                    </div>
                </a>
                <a href="{{ site.affiliates.wise.url }}" target="_blank" rel="sponsored noopener" class="stack-item glass-panel">
                    <div class="stack-icon">💳</div>
                    <div class="stack-info">
                        <div class="stack-name">Wise</div>
                        <div class="stack-desc">Borderless Banking</div>
                    </div>
                </a>
                <a href="{{ site.affiliates.remote.url }}" target="_blank" rel="sponsored noopener" class="stack-item glass-panel">
                    <div class="stack-icon">💼</div>
                    <div class="stack-info">
                        <div class="stack-name">Remote.com</div>
                        <div class="stack-desc">Payroll & Compliance</div>
                    </div>
                </a>
                <a href="{{ site.affiliates.nomadlist.url }}" target="_blank" rel="sponsored noopener" class="stack-item glass-panel">
                    <div class="stack-icon">🌍</div>
                    <div class="stack-info">
                        <div class="stack-name">Nomad List</div>
                        <div class="stack-desc">City & Community</div>
                    </div>
                </a>
                <a href="{{ site.affiliates.lexidy.url }}" target="_blank" rel="sponsored noopener" class="stack-item glass-panel">
                    <div class="stack-icon">⚖️</div>
                    <div class="stack-info">
                        <div class="stack-name">Lexidy</div>
                        <div class="stack-desc">Visa Legal Experts</div>
                    </div>
                </a>
            </div>
        </div>

        <div class="metric-card commentary-box">
            <div class="metric-label">Budget Commentary</div>
            <p id="aura-commentary" class="commentary-text">
                Your financial vitality is strong. Based on current tax laws and city metrics, you are in the top 15% of earners in this location.
            </p>
        </div>

        {# Pro Report (Premium View) #}
        {% include "partials/pro-report.njk" %}

        {# Pro Report Upsell #}
        <div id="pro-upsell" class="glass-panel upsell-panel">
            <div class="upsell-container">
                <div class="upsell-content">
                    <div class="badge-2026 upsell-badge">PREMIUM REPORT</div>
                    <h3 class="upsell-title">Unlock Full Financial Breakdown</h3>
                    <ul class="upsell-features">
                        <li>Detailed 2026 Tax Optimization Strategy</li>
                        <li>Local Apartment & Utility Estimates</li>
                        <li>Nomad Community & Co-working Heatmap</li>
                        <li>Direct Visa Lawyer Contact List</li>
                    </ul>
                    <div class="upsell-footer">
                        <div class="upsell-price">$19</div>
                        <button id="unlock-pro-btn" class="action-btn accent-bg">Unlock Full Report →</button>
                    </div>
                </div>
                <div class="upsell-visual">
                    <div class="upsell-mockup">
                        <div class="mockup-line"></div>
                        <div class="mockup-line"></div>
                        <div class="mockup-line short"></div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {# Empty State (Visible on load) #}
    <section id="empty-state" class="empty-state reveal">
        <div class="empty-content">
            <div class="aura-pulse"></div>
            <h2 class="aura-title">Awaiting Calculations...</h2>
            <p>Enter your income and destination to generate your 2026 financial roadmap.</p>
        </div>
    </section>
</div>

{# Lead Capture Section #}
<section class="lead-section reveal">
    <div class="lead-card glass-panel">
        <div class="lead-content">
            <h2 class="aura-title">2026 Global Tax Guide</h2>
            <p>Get our updated PDF on the top 10 tax-free countries for digital nomads in 2026.</p>
            <div class="lead-form">
                <input type="email" id="lead-email" placeholder="nomad@example.com" class="aura-input">
                <button id="send-guide-btn" class="action-btn accent-bg">Send Me the Guide</button>
            </div>
            <p id="lead-success" class="success-msg hidden">✅ Sent! Check your inbox in a few minutes.</p>
        </div>
    </div>
</section>
