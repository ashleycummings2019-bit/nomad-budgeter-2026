---
layout: layouts/base.njk
pagination:
  data: cities
  size: 1
  alias: city
permalink: "/cities/{{ city.slug }}/"
eleventyComputed:
  pageTitle: "{{ city.name }} Digital Nomad Tax & Cost of Living Calculator (2026)"
  pageDescription: "Calculate your nomad budget in {{ city.name }}, {{ city.country }}. {{ city.visa }} with {{ city.tax | percentInt }} tax rate. Updated for 2026."
  prefillCity: "{{ city.name }}"
---

{# City Hero Section #}
<div class="city-hero">
    <div class="badge-2026" style="margin-bottom: 1rem;">
        <span style="display:inline-block; width:8px; height:8px; background:#10b981; border-radius:50%; margin-right:5px;"></span>
        Verified {{ site.year }} Data
    </div>
    <h1>{{ city.name }} Digital Nomad<br>Tax & Budget Calculator</h1>
    <p style="color: var(--text-dim); font-size: 1.15rem; margin-top: 1rem;">{{ city.country }} · {{ city.visa }} · {{ city.tax * 100 }}% Tax Rate</p>

    <div class="city-highlights">
        {% for highlight in city.highlights %}
        <span class="highlight-chip">{{ highlight }}</span>
        {% endfor %}
    </div>
</div>

{# City Introduction (unique per page — prevents thin content) #}
<div class="comparison-container">
    <div class="expert-analysis" style="margin-top: 2rem;">
        <h2 style="color: var(--aura-primary); margin-bottom: 1rem;">{{ city.name }} for Digital Nomads in {{ site.year }}</h2>
        <p style="color: var(--text-main);">{{ city.intro }}</p>

        {# Key Stats Grid #}
        <div class="metric-grid" style="margin-top: 2rem;">
            <div class="metric-card">
                <div class="metric-label">Monthly Cost of Living</div>
                <div class="metric-value highlight">${{ city.col | localeString }}</div>
            </div>
            <div class="metric-card">
                <div class="metric-label">Average Rent (1BR Center)</div>
                <div class="metric-value">${{ city.rent | localeString }}</div>
            </div>
            <div class="metric-card">
                <div class="metric-label">Nomad Visa Tax Rate</div>
                <div class="metric-value {% if city.tax == 0 %}positive{% endif %}">{{ city.tax * 100 }}%</div>
            </div>
            <div class="metric-card">
                <div class="metric-label">Minimum Income Required</div>
                <div class="metric-value">${{ city.visaMinIncome | localeString }}/mo</div>
            </div>
        </div>

        {# Nomad Score #}
        <div style="text-align: center; margin-top: 2rem; padding: 2rem; background: rgba(15,23,42,0.5); border-radius: 20px; border: 1px solid var(--glass-border);">
            <div class="metric-label">Nomad Score</div>
            <div style="font-size: 3.5rem; font-weight: 800; background: linear-gradient(135deg, #fff, var(--aura-primary)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">{{ city.score }}/100</div>
        </div>
    </div>
</div>

{# Calculator Widget (prefilled with this city) #}
<div class="app-container" style="margin-top: 4rem;">
    {% set prefillCity = city.name %}
    {% include "partials/calculator.njk" %}

    <main id="results-panel" class="glass-panel hidden">
        <div class="results-header">
            <div>
                <h2>Financial Analysis</h2>
                <p id="city-badge">{{ city.name }}, {{ city.country }}</p>
            </div>
            <div class="aura-score" id="aura-ring">
                <span id="aura-value">{{ city.score }}</span>
            </div>
        </div>
        <div class="metric-grid">
            <div class="metric-card">
                <div class="metric-label">Take-Home Pay (Monthly)</div>
                <div class="metric-value highlight" id="res-net-monthly">$0</div>
            </div>
            <div class="metric-card">
                <div class="metric-label">Effective Tax Rate</div>
                <div class="metric-value" id="res-tax-rate">0%</div>
            </div>
            <div class="metric-card">
                <div class="metric-label">Cost of Living Index</div>
                <div class="metric-value" id="res-col-index">High</div>
            </div>
            <div class="metric-card">
                <div class="metric-label">Monthly Savings Potential</div>
                <div class="metric-value positive" id="res-savings">$0</div>
            </div>
        </div>
        <div id="visa-roi-card" class="metric-card hidden" style="margin-top: 1.5rem; width: 100%; background: linear-gradient(135deg, rgba(16, 185, 129, 0.1), rgba(15, 23, 42, 0.5)); border-color: #10b981;">
            <div style="display: flex; justify-content: space-between; align-items: center;">
                <div>
                    <div class="metric-label" style="color: #10b981;">Visa ROI Tracker</div>
                    <p style="font-size: 0.85rem; color: var(--text-dim);">Time to recover visa & setup costs via tax savings.</p>
                </div>
                <div style="text-align: right;">
                    <div class="metric-value positive" id="res-payback">0 Months</div>
                    <div style="font-size: 0.8rem; color: #10b981; font-weight: 600;" id="res-roi-savings">+$0 / yr</div>
                </div>
            </div>
        </div>

        {# Success Stack (Affiliates) #}
        <div style="margin-top: 2rem;">
            <h3 style="font-size: 1rem; margin-bottom: 1rem; color: var(--text-main);">Your Nomad Success Stack</h3>
            <div class="stack-grid">
                <a href="{{ site.affiliates.safetywing.url }}" target="_blank" rel="sponsored noopener" class="stack-item glass-panel">
                    <div class="stack-icon">🛡️</div>
                    <div class="stack-info">
                        <div class="stack-name">SafetyWing</div>
                        <div class="stack-desc">Global Health Cover</div>
                    </div>
                </a>
                <a href="{{ site.affiliates.wise.url }}" target="_blank" rel="sponsored noopener" class="stack-item glass-panel">
                    <div class="stack-icon">💳</div>
                    <div class="stack-info">
                        <div class="stack-name">Wise</div>
                        <div class="stack-desc">Borderless Banking</div>
                    </div>
                </a>
                <a href="{{ site.affiliates.remote.url }}" target="_blank" rel="sponsored noopener" class="stack-item glass-panel">
                    <div class="stack-icon">💼</div>
                    <div class="stack-info">
                        <div class="stack-name">Remote.com</div>
                        <div class="stack-desc">Payroll &amp; Compliance</div>
                    </div>
                </a>
                <a href="{{ site.affiliates.nomadlist.url }}" target="_blank" rel="sponsored noopener" class="stack-item glass-panel">
                    <div class="stack-icon">🌍</div>
                    <div class="stack-info">
                        <div class="stack-name">Nomad List</div>
                        <div class="stack-desc">City &amp; Community</div>
                    </div>
                </a>
                <a href="{{ site.affiliates.lexidy.url }}" target="_blank" rel="sponsored noopener" class="stack-item glass-panel">
                    <div class="stack-icon">⚖️</div>
                    <div class="stack-info">
                        <div class="stack-name">Lexidy</div>
                        <div class="stack-desc">Visa Legal Experts</div>
                    </div>
                </a>
            </div>
        </div>
        <div class="metric-card" style="margin-top: 1.5rem; width: 100%;">
            <div class="metric-label">Budget Commentary</div>
            <p id="aura-commentary" style="line-height: 1.6; color: var(--text-main);"></p>
        </div>

        {# Pro Report Upsell #}
        <div id="pro-upsell" class="glass-panel" style="margin-top: 1.5rem; border: 1px solid #f59e0b; background: linear-gradient(135deg, rgba(245, 158, 11, 0.1), rgba(15, 23, 42, 0.5));">
            <div style="display: flex; justify-content: space-between; align-items: center; gap: 1.5rem; flex-wrap: wrap;">
                <div style="flex: 1; min-width: 250px;">
                    <div class="badge-2026" style="background: rgba(245, 158, 11, 0.15); color: #f59e0b; border-color: rgba(245, 158, 11, 0.3); margin-bottom: 0.5rem;">PREMIUM REPORT</div>
                    <h3 style="color: #fff; margin-bottom: 0.5rem;">Unlock Full Financial Breakdown</h3>
                    <ul style="font-size: 0.85rem; color: var(--text-dim); padding-left: 1.2rem; margin-bottom: 1rem;">
                        <li>Detailed 2026 Tax Optimization Strategy</li>
                        <li>Local Apartment & Utility Estimates</li>
                        <li>Nomad Community & Co-working Heatmap</li>
                        <li>Direct Visa Lawyer Contact List</li>
                    </ul>
                    <div style="display: flex; align-items: center; gap: 1rem;">
                        <div style="font-size: 1.5rem; font-weight: 800; color: #fff;">$19</div>
                        <button id="unlock-pro-btn" class="action-btn" style="background: #f59e0b; color: #000; flex: 1;">Unlock Pro →</button>
                    </div>
                </div>
                <div style="flex: 0 0 160px; display: flex; justify-content: center;">
                    <img src="/assets/images/pro-mockup.png" alt="Pro Report Mockup" style="width: 100%; border-radius: 8px; box-shadow: 0 10px 30px rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.1);">
                </div>
            </div>
        </div>
        <div class="trust-badge">
            <span>📊 Tax data last verified: {{ site.dataLastVerified }}</span>
            <span>🤖 Human-verified for {{ site.year }} compliance.</span>
        </div>
    </main>

    <main id="empty-state" class="glass-panel" style="display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; min-height: 300px;">
        <div style="font-size: 3rem; margin-bottom: 1rem;">🧮</div>
        <h2>Calculate your {{ city.name }} budget</h2>
        <p style="color: var(--text-dim); max-width: 300px; margin-top: 0.75rem;">Enter your income to see your personalized {{ city.name }} financial breakdown.</p>
    </main>
</div>

{# Related Comparisons #}
<div class="comparison-container" style="margin-top: 4rem;">
    <h2 style="text-align: center; margin-bottom: 2rem;">Compare {{ city.name }} with Other Hubs</h2>
    <div class="partner-grid">
        {% for comp in comparisons %}
        {% if (comp.cityA.slug == city.slug or comp.cityB.slug == city.slug) and loop.index <= 20 %}
        <a href="/compare/{{ comp.slug }}/" class="partner-card">
            <h4>{{ comp.cityA.name }} vs. {{ comp.cityB.name }}</h4>
            <p>{{ comp.theme }} · Winner: {{ comp.winner }}</p>
        </a>
        {% endif %}
        {% endfor %}
    </div>
</div>

<div class="comparison-container" style="margin-top: 2rem;">
    {% include "partials/relocation-toolkit.njk" %}
    {% include "partials/seo-silos.njk" %}
</div>
