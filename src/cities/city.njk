---
layout: layouts/base.njk
pagination:
  data: cities
  size: 1
  alias: city
permalink: "/cities/{{ city.slug }}/"
eleventyComputed:
  pageTitle: "{{ city.name }} Digital Nomad Tax & Cost of Living Calculator (2026)"
  pageDescription: "Calculate your nomad budget in {{ city.name }}, {{ city.country }}. {{ city.visa }} with {{ city.tax | percentInt }} tax rate. Updated for 2026."
  prefillCity: "{{ city.name }}"
---

{# City Hero Section #}
<div class="city-hero section-container">
    <div class="badge-2026 mb-4">
        <span class="badge-dot"></span>
        Verified {{ site.year }} Market Data
    </div>
    <h1 class="aura-title large-title">{{ city.name }} Nomad Tax<br>& Budget Calculator</h1>
    <p class="text-dim subtitle-text">{{ city.country }} · {{ city.visa }} · {{ city.tax * 100 }}% Nomad Tax Rate</p>

    <div class="city-highlights mt-6">
        {% for highlight in city.highlights %}
        <span class="highlight-chip">{{ highlight }}</span>
        {% endfor %}
    </div>
</div>

{# City Introduction #}
<div class="section-container mt-16">
    <div class="expert-analysis glass-panel p-8">
        <h2 class="aura-title mb-6">{{ city.name }} for Digital Nomads in {{ site.year }}</h2>
        <p class="text-main">{{ city.intro }}</p>

        {# Key Stats Grid #}
        <div class="metric-grid mt-8">
            <div class="metric-card">
                <div class="metric-label">Monthly Cost of Living</div>
                <div class="metric-value highlight">${{ city.col | localeString }}</div>
            </div>
            <div class="metric-card">
                <div class="metric-label">Average Rent (1BR Center)</div>
                <div class="metric-value">${{ city.rent | localeString }}</div>
            </div>
            <div class="metric-card">
                <div class="metric-label">Nomad Visa Tax Rate</div>
                <div class="metric-value {% if city.tax == 0 %}positive-text{% endif %}">{{ city.tax * 100 }}%</div>
            </div>
            <div class="metric-card">
                <div class="metric-label">Min. Annual Income</div>
                <div class="metric-value">${{ (city.visaMinIncome * 12) | localeString }}</div>
            </div>
        </div>

        {# Nomad Score Panel #}
        <div class="score-panel mt-8">
            <div class="metric-label">Aura Financial Score</div>
            <div class="score-value highlight">{{ city.score }}/100</div>
            <p class="text-dim text-sm">Based on tax efficiency, CoL, and 2026 quality of life indices.</p>
        </div>
    </div>
</div>

{# Calculator Widget #}
<div class="app-container mt-16">
    {% set prefillCity = city.name %}
    {% include "partials/calculator.njk" %}

    <section id="results-panel" class="glass-panel hidden">
        <div class="results-header">
            <div class="header-info">
                <h2 class="aura-title">Personalized Analysis</h2>
                <div class="header-meta">
                    <p id="city-badge" class="city-badge">{{ city.name }}, {{ city.country }}</p>
                    <span class="meta-dot"></span>
                    <p class="trust-indicator">Verified for 2026</p>
                </div>
            </div>
            <div class="aura-score" id="aura-ring">
                <span id="aura-value">{{ city.score }}</span>
            </div>
        </div>

        <div class="metric-grid">
            <div class="metric-card">
                <div class="metric-label">Take-Home Pay (Monthly)</div>
                <div class="metric-value highlight" id="res-net-monthly">$0</div>
            </div>
            <div class="metric-card">
                <div class="metric-label">Effective Tax Rate</div>
                <div class="metric-value" id="res-tax-rate">0%</div>
            </div>
            <div class="metric-card">
                <div class="metric-label">Cost of Living Index</div>
                <div class="metric-value" id="res-col-index">High</div>
            </div>
            <div class="metric-card">
                <div class="metric-label">Monthly Savings Potential</div>
                <div class="metric-value positive" id="res-savings">$0</div>
            </div>
        </div>

        <div id="visa-roi-card" class="metric-card roi-tracker hidden mt-6">
            <div class="flex-between mb-4">
                <div class="roi-info">
                    <div class="metric-label accent-color">Visa ROI Tracker</div>
                    <p class="roi-desc">Time to recover visa & setup costs via tax savings.</p>
                </div>
                <div class="roi-stats">
                    <div class="metric-value positive" id="res-payback">0 Months</div>
                    <div class="roi-yearly-savings" id="res-roi-savings">+$0 / yr</div>
                </div>
            </div>
            <a href="https://citizenremote.com/?ref=nomadbudgeter" target="_blank" rel="sponsored noopener" id="visa-cta" class="action-btn w-full accent-bg">Apply for {{ city.name }} Visa →</a>
        </div>

        {# Success Stack #}
        <div class="success-stack-section mt-8">
            <h3 class="section-subtitle">Your {{ city.name }} Success Stack</h3>
            <div class="stack-grid">
                <a href="{{ site.affiliates.safetywing.url }}" target="_blank" rel="sponsored noopener" class="stack-item glass-panel">
                    <div class="stack-icon">🛡️</div>
                    <div class="stack-info">
                        <div class="stack-name">SafetyWing</div>
                        <div class="stack-desc">Global Health Cover</div>
                    </div>
                </a>
                <a href="{{ site.affiliates.wise.url }}" target="_blank" rel="sponsored noopener" class="stack-item glass-panel">
                    <div class="stack-icon">💳</div>
                    <div class="stack-info">
                        <div class="stack-name">Wise</div>
                        <div class="stack-desc">Borderless Banking</div>
                    </div>
                </a>
                <a href="{{ site.affiliates.remote.url }}" target="_blank" rel="sponsored noopener" class="stack-item glass-panel">
                    <div class="stack-icon">💼</div>
                    <div class="stack-info">
                        <div class="stack-name">Remote.com</div>
                        <div class="stack-desc">Payroll &amp; Compliance</div>
                    </div>
                </a>
                <a href="{{ site.affiliates.nomadlist.url }}" target="_blank" rel="sponsored noopener" class="stack-item glass-panel">
                    <div class="stack-icon">🌍</div>
                    <div class="stack-info">
                        <div class="stack-name">Nomad List</div>
                        <div class="stack-desc">City &amp; Community</div>
                    </div>
                </a>
                <a href="{{ site.affiliates.lexidy.url }}" target="_blank" rel="sponsored noopener" class="stack-item glass-panel">
                    <div class="stack-icon">⚖️</div>
                    <div class="stack-info">
                        <div class="stack-name">Lexidy</div>
                        <div class="stack-desc">Visa Legal Experts</div>
                    </div>
                </a>
            </div>
        </div>

        <div class="metric-card commentary-box mt-6">
            <div class="metric-label">Budget Commentary</div>
            <p id="aura-commentary" class="commentary-text"></p>
        </div>

        {# Pro Report (Premium View) #}
        {% include "partials/pro-report.njk" %}

        {# Pro Report Upsell #}
        <div id="pro-upsell" class="glass-panel upsell-panel mt-6">
            <div class="upsell-container">
                <div class="upsell-content">
                    <div class="badge-2026 upsell-badge">PREMIUM REPORT</div>
                    <h3 class="upsell-title">Unlock {{ city.name }} Deep-Dive</h3>
                    <ul class="upsell-features">
                        <li>Detailed 2026 Tax Optimization Strategy</li>
                        <li>Local Apartment & Utility Estimates</li>
                        <li>Nomad Community & Co-working Heatmap</li>
                        <li>Direct Visa Lawyer Contact List</li>
                    </ul>
                    <div class="upsell-footer">
                        {% set currentTier = pricing.getCountryTier(city.country) %}
                        {% set currentPrice = pricing.tiers[currentTier].price %}
                        <div class="upsell-price">${{ currentPrice }}</div>
                        <button id="unlock-pro-btn" class="action-btn upsell-btn" data-price="{{ currentPrice }}">Unlock Pro →</button>
                    </div>
                </div>
                <div class="upsell-visual">
                    <img src="/assets/images/pro-mockup.png" alt="Pro Report Mockup" class="pro-mockup">
                </div>
            </div>
        </div>

        <div class="trust-badge mt-8">
            <span>📊 Tax data last verified: {{ site.dataLastVerified }}</span>
            <span>🤖 Human-verified for {{ site.year }} compliance.</span>
        </div>

        {# Lead Magnet #}
        {% include "partials/lead-magnet.njk" %}
    </section>

    {# Similar Destinations Section #}
    <div class="section-container mt-24">
        <div class="flex-between mb-8">
            <h2 class="aura-title">Explore Similar Destinations</h2>
            <a href="/" class="view-all-link">Back to Map →</a>
        </div>
        <div class="stack-grid">
            {% set count = 0 %}
            {% for otherCity in cities %}
                {% if otherCity.slug != city.slug and count < 4 %}
                    {% if otherCity.country == city.country or (otherCity.col > city.col * 0.8 and otherCity.col < city.col * 1.2) %}
                        {% set count = count + 1 %}
                        <a href="/cities/{{ otherCity.slug }}/" class="stack-item glass-panel hub-card">
                            <div class="hub-icon">{{ otherCity.emoji | default('📍') }}</div>
                            <div class="hub-info">
                                <div class="hub-name">{{ otherCity.name }}</div>
                                <div class="hub-desc">{{ otherCity.country }} · {{ otherCity.tax | percentInt }} Tax</div>
                            </div>
                        </a>
                    {% endif %}
                {% endif %}
            {% endfor %}
        </div>
    </div>

    {# Related Comparisons #}
    <div class="section-container mt-24">
        <h2 class="aura-title text-center mb-8">Compare {{ city.name }} with Other Hubs</h2>
        <div class="stack-grid">
            {% set compCount = 0 %}
            {% for comp in comparisons %}
                {% if (comp.cityA.slug == city.slug or comp.cityB.slug == city.slug) and compCount < 4 %}
                    {% set compCount = compCount + 1 %}
                    <a href="/compare/{{ comp.slug }}/" class="stack-item glass-panel hub-card">
                        <div class="hub-icon">{{ comp.emoji }}</div>
                        <div class="hub-info">
                            <div class="hub-name">{{ comp.cityA.name }} vs. {{ comp.cityB.name }}</div>
                            <div class="hub-desc">{{ comp.theme }}</div>
                        </div>
                    </a>
                {% endif %}
            {% endfor %}
        </div>
    </div>
</div>

<div class="section-container mt-16">
    {% include "partials/relocation-toolkit.njk" %}
    {% include "partials/seo-silos.njk" %}
</div>
