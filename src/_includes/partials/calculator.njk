{# Embeddable Calculator Widget — Used on homepage, city pages, and comparison pages #}
{# Pass prefillCity and/or compareMode variables to customize behavior #}

{% if compareMode %}
{# Comparison Calculator (for comparison pages) #}
<div class="calculator-widget glass-panel">
    <header class="calculator-header">
        <h2 class="aura-title">Savings Comparison</h2>
        <p class="text-dim">Compare your monthly "Leftover" after tax &amp; rent across these locations.</p>
    </header>
    <div class="calculator-form">
        <div class="input-group">
            <label for="compare-income">Your Annual Gross Income (USD)</label>
            <input type="number" id="compare-income" class="aura-input" placeholder="e.g. 100000"
                   data-desta="{{ destA }}" data-destb="{{ destB }}" required>
        </div>
        <button id="compare-btn" class="action-btn w-full">Compare Net Savings</button>
    </div>
    <div id="comparison-result" class="comparison-result-container"></div>
</div>

{% else %}
{# Standard Calculator (for homepage and city pages) #}
<aside class="glass-panel calculator-sidebar">
    <header class="calculator-header">
        <div class="badge-2026 mb-4">
            <span class="badge-dot"></span>
            Verified {{ site.year }} Market Data
        </div>
        <h2 class="aura-title large-title">{{ site.name }}</h2>
        <p class="text-dim">Calculate your true "Leftover" savings potential. Trusted by <strong>{{ site.socialProof }}</strong> this month.</p>
    </header>

    <div class="calculator-form">
        <div class="input-group">
            <label for="income">Annual Gross Income (USD)</label>
            <input type="number" id="income" class="aura-input" placeholder="e.g. 100000" required>
        </div>

        <div class="input-group">
            <label for="location">Target City</label>
            <input type="text" id="location" class="aura-input" placeholder="e.g. Lisbon, Bali, Dubai"
                   {% if prefillCity %}value="{{ prefillCity }}"{% endif %} required>
        </div>

        <div class="input-group">
            <label for="expenses">Custom Monthly Expenses (Optional)</label>
            <input type="number" id="expenses" class="aura-input" placeholder="We'll use {{ site.year }} local averages if empty">
        </div>

        <div class="input-group">
            <label for="days-in-country">Days in Country (Tax Residency)</label>
            <input type="range" id="days-in-country" min="1" max="365" value="365" class="aura-range">
            <div class="range-labels">
                <span>1 day</span>
                <span id="days-val" class="range-value">365 days</span>
                <span>365 days</span>
            </div>
            <div id="residency-warning" class="residency-warning">
                ⚠️ Over 183 days usually triggers local tax residency.
            </div>
        </div>

        <div class="input-group grid-2 stack-on-mobile">
            <div class="input-field">
                <label for="employment-type" class="field-label">Work Status</label>
                <select id="employment-type" class="aura-input">
                    <option value="freelancer">Freelancer / B2B</option>
                    <option value="employee">W2 Employee</option>
                </select>
            </div>
            <div class="input-field">
                <label for="us-citizen" class="field-label">US Citizen?</label>
                <select id="us-citizen" class="aura-input">
                    <option value="no">No</option>
                    <option value="yes">Yes (FEIE)</option>
                </select>
            </div>
        </div>

        <button id="calculate-btn" class="action-btn w-full centered-btn">Sync Market Data &amp; Calculate</button>
    </div>

    <div id="loading" class="hidden loading-container">
        <div class="spinner"></div>
        <p class="loading-text">Connecting to Live Data Nodes...</p>
    </div>
</aside>
{% endif %}
